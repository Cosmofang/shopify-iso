{
  "$meta": {
    "name": "Shopify ISO — Polaris v14 design tokens (BFS compliant)",
    "note": "Machine-readable tokens for Figma sync / validation. Primary button = color.bg.fill.brand (#1a1a1a), NOT green.",
    "polarisVersion": "14+"
  },
  "color": {
    "bg": {
      "default": "#f1f1f1",
      "surface": "#ffffff",
      "surfaceHover": "#f7f7f7",
      "surfaceActive": "#f3f3f3",
      "inverse": "#1a1a1a",
      "surfaceInfo": "#eaf4ff",
      "surfaceSuccess": "#cdfed4",
      "surfaceCaution": "#fff8db",
      "surfaceWarning": "#fff1e3",
      "surfaceCritical": "#fee8eb",
      "surfaceEmphasis": "#f0f2ff",
      "surfaceMagic": "#f8f7ff",
      "fill": {
        "brand": "#1a1a1a",
        "brandHover": "#3d3d3d",
        "success": "#047b5d",
        "warning": "#ffb800",
        "caution": "#ffe600",
        "critical": "#c70a24",
        "info": "#91d0ff"
      }
    },
    "text": {
      "default": "#303030",
      "secondary": "#616161",
      "disabled": "#b5b5b5",
      "critical": "#8e0b21",
      "caution": "#4f4700",
      "success": "#014b40",
      "info": "#003a5a",
      "emphasis": "#005bd3",
      "brandOnBgFill": "#ffffff"
    },
    "border": {
      "default": "#e3e3e3",
      "secondary": "#ebebeb",
      "focus": "#005bd3",
      "critical": "#fec1c7",
      "success": "#92fcac",
      "caution": "#ffeb78"
    },
    "icon": {
      "default": "#4a4a4a",
      "secondary": "#616161",
      "critical": "#e22c38"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, monospace"
    },
    "fontSize": { "275": 11, "300": 12, "325": 13, "350": 14, "400": 16, "450": 18, "500": 20, "600": 24, "750": 30, "800": 32, "900": 36 },
    "fontWeight": { "regular": 450, "medium": 550, "semibold": 650, "bold": 700 },
    "lineHeight": { "300": 12, "400": 16, "500": 20, "600": 24, "700": 28, "800": 32, "1000": 40, "1200": 48 }
  },
  "space": { "050": 2, "100": 4, "150": 6, "200": 8, "300": 12, "400": 16, "500": 20, "600": 24, "800": 32, "1000": 40, "1200": 48, "1600": 64 },
  "borderRadius": { "100": 4, "150": 6, "200": 8, "300": 12, "400": 16, "500": 20, "full": 9999 },
  "borderWidth": { "025": 1, "050": 2, "100": 4 },
  "breakpoints": { "sm": 490, "md": 768, "lg": 1040, "xl": 1440 },
  "wcag": {
    "minContrastNormalText": 4.5,
    "minContrastLargeText": 3.0,
    "minContrastNonText": 3.0,
    "forbiddenTextOnWhite": ["#8c9196", "#b5b5b5"]
  },
  "bfsRules": {
    "primaryButton": "color.bg.fill.brand (#1a1a1a) only; never #008060 or brand color",
    "redColor": "only for errors and destructive actions",
    "autoModal": "forbidden; modals only on user click",
    "errorMessage": "each errored field needs actionable text, not just red border",
    "appNameNoTruncate": true,
    "navToHomepage": true,
    "mobileTouchTargetPx": 44
  }
}
